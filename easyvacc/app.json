{
  "expo": {
    "name": "easyvacc",
    "slug": "easyvacc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "easyvacc",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "EasyVacc",
      "shortName": "EasyVacc",
      "lang": "pt-BR",
      "scope": "/",
      "themeColor": "#2E86DE",
      "description": "Vacinas, postos de saúde e equipe — dados salvos localmente no aparelho.",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O EasyVacc usa sua localização para ordenar os postos por distância."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O app acessa a galeria para a foto do perfil.",
          "cameraPermission": "O app usa a câmera para a foto do perfil."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
