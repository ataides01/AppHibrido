# Copie para .env e ajuste. Com URL definida, o app usa a easyvacc-api (JWT + SQLite).
# Web / iOS simulator:
EXPO_PUBLIC_API_URL=http://127.0.0.1:3333
# Android emulador (substitui localhost):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3333
# Celular na mesma Wi‑Fi — use o IP da sua máquina:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3333
